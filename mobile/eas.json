{
  "cli": {
    "version": ">= 15.0.0"
  },
  "build": {
    "base": {
      "node": "20.19.4",
      "env": {
        "NODE_ENV": "development"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": {
        "image": "macos-sequoia-15.3-xcode-16.2",
        "simulator": false
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "environment": "preview",
      "ios": {
        "image": "macos-sequoia-15.3-xcode-16.2"
      }
    },
    "production": {
      "extends": "base",
      "environment": "production",
      "ios": {
        "image": "macos-sequoia-15.3-xcode-16.2"
      }
    },
    "development-simulator": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": {
        "image": "macos-sequoia-15.3-xcode-16.2",
        "simulator": true
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6759113274"
      }
    }
  }
}
