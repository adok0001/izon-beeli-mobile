# Clerk authentication (required)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend API base URL (required) — defaults to http://localhost:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Igbo dictionary API token (required for Igbo lookups)
EXPO_PUBLIC_IGBO_API_TOKEN=

# PartyKit host for multiplayer (defaults to localhost:1999)
EXPO_PUBLIC_PARTYKIT_HOST=localhost:1999

# PostHog analytics — analytics are disabled when the key is unset
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
