    "XpLevelBadge": { "cardMode": "column" }
  },
  "componentSrcMap": {
    "Button": "components/ui/button.tsx",
    "Badge": "components/ui/badge.tsx",
    "SectionHeader": "components/ui/section-header.tsx",
    "ExhibitDivider": "components/ui/section-header.tsx",
    "ScreenContainer": "components/ui/screen-container.tsx",
    "LocalizedTextInput": "components/ui/localized-text-input.tsx",
    "LanguagePicker": "components/ui/language-picker.tsx",
    "DueDatePicker": "components/ui/due-date-picker.web.tsx",
    "IconSymbol": "components/ui/icon-symbol.tsx",
    "XpLevelBadge": "components/xp-level-badge.tsx",
    "ProverbCard": "components/proverb-card.tsx",
    "WordOfTheDay": "components/word-of-the-day.tsx",
    "ProverbOfTheDay": "components/proverb-of-the-day.tsx",
    "DiscoverCard": "components/discover-card.tsx",
    "DailyChallengeCards": "components/daily-challenge-card.tsx",
    "UpNextCard": "components/up-next-card.tsx",
    "WordChallengeCard": "components/word-challenge-card.tsx",
    "ContributionSpotlightCard": "components/contribution-spotlight-card.tsx"
  }
