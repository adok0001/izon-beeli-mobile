{
  "expo": {
    "name": "Beeli",
    "slug": "izon-beeli-mobile",
    "version": "1.32.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "izonbeelimobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.izonbeeli.app",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.izonbeeli.shared"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.izonbeeli.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Beeli to access your microphone to record audio contributions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#246BFD",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "./modules/beeli-widget/plugin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f58ed9fc-5836-4660-9c9d-2e73f96b0c8d"
      }
    },
    "owner": "tammyado",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/f58ed9fc-5836-4660-9c9d-2e73f96b0c8d"
    }
  }
}
